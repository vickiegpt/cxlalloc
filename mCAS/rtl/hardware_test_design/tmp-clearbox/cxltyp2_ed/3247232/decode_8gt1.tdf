--synthesis_resources = lut 4 
SUBDESIGN decode_8gt1
( 
	data[1..0]	:	input;
	enable	:	input;
	eq[3..0]	:	output;
) 
VARIABLE 
	data_wire[1..0]	: WIRE;
	enable_wire	: WIRE;
	eq_node[3..0]	: WIRE;
	eq_wire[3..0]	: WIRE;
	w_anode44763w[2..0]	: WIRE;
	w_anode44776w[2..0]	: WIRE;
	w_anode44784w[2..0]	: WIRE;
	w_anode44792w[2..0]	: WIRE;

BEGIN 
	data_wire[] = data[];
	enable_wire = enable;
	eq[] = eq_node[];
	eq_node[3..0] = eq_wire[3..0];
	eq_wire[] = ( w_anode44792w[2..2], w_anode44784w[2..2], w_anode44776w[2..2], w_anode44763w[2..2]);
	w_anode44763w[] = ( (w_anode44763w[1..1] & (! data_wire[1..1])), (w_anode44763w[0..0] & (! data_wire[0..0])), enable_wire);
	w_anode44776w[] = ( (w_anode44776w[1..1] & (! data_wire[1..1])), (w_anode44776w[0..0] & data_wire[0..0]), enable_wire);
	w_anode44784w[] = ( (w_anode44784w[1..1] & data_wire[1..1]), (w_anode44784w[0..0] & (! data_wire[0..0])), enable_wire);
	w_anode44792w[] = ( (w_anode44792w[1..1] & data_wire[1..1]), (w_anode44792w[0..0] & data_wire[0..0]), enable_wire);
END;
